# Joyus AI — Environment Variables
# Copy to .env and fill in real values: cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=jawn_ai
POSTGRES_USER=jawn
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://jawn:changeme@postgres:5432/jawn_ai

# --- Encryption ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=generate-a-32-byte-hex-key

# --- MCP Authentication ---
# Bearer token for MCP client connections (Claude Desktop, etc.)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_BEARER_TOKEN=generate-a-secure-token

# --- Claude API (for web chat UI) ---
CLAUDE_API_KEY=sk-ant-...

# --- Session ---
SESSION_SECRET=generate-a-secure-session-secret

# --- OAuth Credentials ---
# Jira / Atlassian
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Domain & TLS ---
DOMAIN=ai.zivtech.com
LETSENCRYPT_EMAIL=admin@zivtech.com
BASE_URL=https://ai.zivtech.com

# --- Slack Webhook (monitoring alerts) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Web Chat ---
WEB_CHAT_TOKEN=generate-a-web-chat-token
